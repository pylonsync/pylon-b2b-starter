{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && bun install --frozen-lockfile && cd apps/dashboard && bun run build",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "installCommand": "echo 'install handled by buildCommand'",
  "env": {
    "PYLON_BASE_URL": "@pylon_base_url",
    "NEXT_PUBLIC_PYLON_URL": "@next_public_pylon_url"
  }
}
