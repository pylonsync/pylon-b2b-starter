{
  "name": "pylon-b2b-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "packageManager": "bun@1.2.19",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.0",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3"
  }
}
